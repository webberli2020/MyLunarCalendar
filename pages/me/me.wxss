.container {
  padding: 60rpx 40rpx;
  background-color: #F5F5F7;
  height: min-content;
  min-height: 100vh;
}
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}
.app-logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}
.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #1C1C1E;
}
.app-ver {
  font-size: 24rpx;
  color: #8E8E93;
  margin-top: 8rpx;
}
.section {
  background: white;
  border-radius: 36rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.02);
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
  color: #1C1C1E;
}
.feature-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  color: #48484A;
}
.feature-item icon {
  margin-top: 6rpx;
  margin-right: 20rpx;
}
.footer {
  margin-top: 100rpx;
  text-align: center;
  font-size: 24rpx;
  color: #AEAEB2;
}
