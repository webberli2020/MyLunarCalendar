page {
  background-color: #F5F5F7;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  height: 100%;
  overflow: hidden; 
}
.calendar-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  padding-top: 20rpx;
}
.header-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx;
  margin-bottom: 20rpx;
}
.year-month-selector {
  display: flex;
  align-items: center;
}
.year-month-selector:active {
  opacity: 0.6;
}
.year-month-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #1c1c1e;
}
.arrow-down {
  font-size: 28rpx;
  color: #8E8E93;
  margin-left: 12rpx;
  margin-top: 6rpx;
}
.action-btn {
  font-size: 26rpx;
  color: #007AFF;
  font-weight: 500;
  padding: 10rpx 24rpx;
  background: rgba(0, 122, 255, 0.1);
  border-radius: 30rpx;
}
.week-header {
  display: flex;
  justify-content: space-around;
  padding: 0 10rpx;
  margin-bottom: 20rpx;
}
.week-item {
  font-size: 24rpx;
  color: #8E8E93;
  width: 14.28%;
  text-align: center;
  font-weight: 500;
}
.week-item.weekend {
  color: #C7C7CC;
}
.month-swiper {
  height: 640rpx; 
  width: 100%;
}
.days-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 10rpx;
}
.day-cell {
  position: relative;
  width: 14.28%;
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 6rpx;
  z-index: 1;
}
.day-bg {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  z-index: -1;
  transition: background-color 0.25s cubic-bezier(0.25, 0.1, 0.25, 1);
}
.selected-bg {
  background-color: #007AFF;
  box-shadow: 0 10rpx 20rpx rgba(0, 122, 255, 0.25);
}
.day-num {
  font-size: 34rpx;
  font-weight: 500;
  color: #1C1C1E;
}
.day-lunar {
  font-size: 20rpx;
  color: #8E8E93;
  margin-top: 2rpx;
}
.disabled .day-num,
.disabled .day-lunar {
  color: #D1D1D6;
}
.weekend .day-num {
  color: #FF3B30; 
  opacity: 0.8;
}
.day-cell.today .day-num {
  color: #007AFF;
  font-weight: bold;
}
.day-cell.today .day-lunar {
  color: #007AFF;
}
.selected-text {
  color: #FFFFFF !important;
}
.holiday-text {
  color: #FF3B30;
}
.work-badge, .rest-badge {
  position: absolute;
  top: 4rpx;
  right: 12rpx;
  font-size: 18rpx;
  padding: 2rpx 6rpx;
  border-radius: 6rpx;
  font-weight: bold;
  color: #fff;
  transform: scale(0.9);
}
.work-badge {
  background-color: #34C759; 
}
.rest-badge {
  background-color: #FF3B30; 
}
.detail-card {
  flex: 1;
  background-color: #FFFFFF;
  margin: 10rpx 30rpx 40rpx;
  border-radius: 36rpx;
  box-shadow: 0 12rpx 36rpx rgba(0,0,0,0.03);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}
.card-header {
  border-bottom: 1rpx solid #E5E5EA;
  padding-bottom: 24rpx;
  margin-bottom: 24rpx;
}
.card-date {
  font-size: 42rpx;
  font-weight: 600;
  color: #1C1C1E;
  display: block;
}
.card-nongli {
  font-size: 28rpx;
  color: #8E8E93;
  margin-top: 10rpx;
  display: block;
}
.info-row {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}
.info-label {
  color: #8E8E93;
  width: 150rpx;
}
.info-value {
  color: #1C1C1E;
  flex: 1;
}
.highlight {
  color: #FF3B30;
}
.holiday-cn {
  color: #FF3B30; /* 赤红色 */
}
.holiday-us {
  color: #007AFF; /* 联邦蓝色 */
}
.holiday-br {
  color: #34C759; /* 森绿色 */
}
/* ================== Picker ================== */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}
.picker-mask-show {
  opacity: 1;
  visibility: visible;
}
.picker-popup, .pto-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #F9F9F9;
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  padding-bottom: env(safe-area-inset-bottom);
}
.picker-popup-show, .pto-popup-show {
  transform: translateY(0);
}
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  background-color: #FFFFFF;
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  border-bottom: 1rpx solid #E5E5EA;
}
.picker-btn {
  font-size: 32rpx;
  padding: 10rpx 0;
}
.picker-btn.cancel {
  color: #8E8E93;
}
.picker-btn.confirm {
  color: #007AFF;
  font-weight: 600;
}
.picker-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1C1C1E;
}
.custom-picker {
  width: 100%;
  height: 480rpx;
  background-color: #FFFFFF;
}
.picker-indicator {
  height: 88rpx;
  background-color: rgba(0, 122, 255, 0.06); 
  border-top: none;
  border-bottom: none;
}
.picker-item {
  line-height: 88rpx;
  text-align: center;
  font-size: 38rpx;
  color: #1C1C1E;
  font-weight: 500;
}
/* ================== PTO ================== */
.pto-entry-btn {
  margin-top: 30rpx;
  padding: 24rpx;
  background-color: #F2F2F7;
  border-radius: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #007AFF;
  font-weight: 500;
  border: 1rpx solid #E5E5EA;
}
.pto-entry-btn:active { opacity: 0.6; }
.pto-content { padding: 40rpx; }
.segment-control {
  display: flex;
  background-color: #E5E5EA;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 40rpx;
}
.segment-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #8E8E93;
  padding: 14rpx 0;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}
.segment-item.active {
  background-color: #FFFFFF;
  color: #1C1C1E;
  font-weight: 600;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.06);
}
.date-range-box {
  display: flex; align-items: center; justify-content: space-between;
  background: #FFFFFF; border-radius: 24rpx; padding: 36rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
}
.date-block { display: flex; flex-direction: column; align-items: center; }
.date-label { font-size: 24rpx; color: #8E8E93; margin-bottom: 12rpx; }
.date-value { font-size: 38rpx; color: #1C1C1E; font-weight: 600; }
.date-arrow { color: #D1D1D6; font-size: 32rpx; font-weight: bold; }
.calc-btn {
  background-color: #007AFF; color: #FFFFFF;
  text-align: center; padding: 28rpx 0;
  border-radius: 24rpx; font-size: 32rpx; font-weight: 600;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 122, 255, 0.25);
  transition: opacity 0.2s;
}
.calc-btn:active { opacity: 0.7; }
.result-box {
  background: rgba(52, 199, 89, 0.1); border-radius: 20rpx;
  padding: 30rpx; text-align: center;
}
.result-number { color: #34C759; font-weight: bold; font-size: 32rpx; }
.big-num { font-size: 64rpx; margin: 0 10rpx; }
.result-desc { font-size: 24rpx; color: #4A4A4A; margin-top: 16rpx; line-height: 1.5; }
